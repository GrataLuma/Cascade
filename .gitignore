# Build outputs
**/bin/
**/obj/
**/.vs/

# Evaluation run artifacts — large binaries / verbose logs regenerated locally.
# Patterns scoped to **/reports/ catch both root-level reports/ and
# EmpiricalEvaluation/reports/. Markdown/CSV reports stay tracked (audit trail).
**/reports/transcripts_*.bin
**/reports/transcripts_*.idx
**/reports/keys_*.bin

# EmpiricalEvaluation/reports/ legacy patterns (kept verbose for historical clarity)
EmpiricalEvaluation/reports/*.bin
EmpiricalEvaluation/reports/*.idx
EmpiricalEvaluation/reports/*.log
EmpiricalEvaluation/reports/a1_stdout.txt

# Golden reference files ARE committed intentionally (cross-migration bit-exact baseline)
!EmpiricalEvaluation/reports/golden/

# LaTeX build artifacts (paper/ contains .tex source + .pdf output; intermediates are local)
paper/**/*.aux
paper/**/*.fls
paper/**/*.fdb_latexmk
paper/**/*.synctex.gz
paper/**/*.bbl
paper/**/*.blg
paper/**/*.ind
paper/**/*.ilg
paper/**/*.out
paper/**/*.toc

# IDE
*.user
*.suo
.idea/
.vscode/

# OS
Thumbs.db
.DS_Store

# NuGet
packages/
*.nupkg

# Archive blobs
*.zip

# F7 distribution staging (regenerated by scripts/build-release.ps1)
release/

# Claude Code local state
.claude/

# Blazor WASM build outputs (regenerated per build)
**/wwwroot/_framework/
**/.publish/
**/wwwroot/*.map

# Deployment publish output (`dotnet publish -o publish/`)
/publish/
